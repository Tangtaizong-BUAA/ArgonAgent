{
  "provider_id": "openai_compatible_lab",
  "schema_version": "v0",
  "display_name": "Lab OpenAI-Compatible Endpoint",
  "protocol": "openai_compatible",
  "base_url": "http://127.0.0.1:8000/v1",
  "api_key_env": "LAB_OPENAI_COMPAT_API_KEY",
  "actual_model_name": "custom-coder-32b",
  "display_model_name": "Custom Coder 32B",
  "model_alias": "lab-coder",
  "headers": {},
  "capability_hints": {
    "supports_streaming": true,
    "supports_tools": true,
    "max_context_tokens": 32768
  },
  "request_transform": {
    "id": "openai_chat_default_v0"
  },
  "response_transform": {
    "id": "openai_chat_default_v0"
  },
  "health_check": {
    "enabled": true,
    "method": "chat_minimal",
    "timeout_ms": 5000,
    "requires_auth": true,
    "non_sensitive_prompt": "Reply with OK.",
    "expected_response_shape": ["choices"]
  },
  "enabled_by_default": false,
  "optimization_level": "compatible"
}

