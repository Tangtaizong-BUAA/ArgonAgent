{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcode.local/schemas/provider/model_alias_mapping.schema.json",
  "title": "ModelAliasMapping",
  "type": "object",
  "required": ["provider_id", "schema_version", "model_alias", "actual_model_name", "display_model_name"],
  "additionalProperties": false,
  "properties": {
    "provider_id": {"type": "string"},
    "schema_version": {"type": "string", "pattern": "^v[0-9]+$"},
    "model_alias": {"type": "string"},
    "actual_model_name": {"type": "string"},
    "display_model_name": {"type": "string"},
    "base_url_override": {"type": "string"},
    "request_transform_id": {"type": "string"},
    "response_transform_id": {"type": "string"},
    "notes": {"type": "string"}
  }
}

