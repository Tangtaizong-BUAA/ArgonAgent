{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://researchcode.local/schemas/kernel/plan_approval_request.schema.json",
  "title": "PlanApprovalRequest",
  "type": "object",
  "required": ["plan_approval_id", "schema_version", "session_id", "plan_id", "plan_summary", "planned_steps", "expected_paths", "expected_commands", "model_profile_id", "governance_risk", "request_hash"],
  "additionalProperties": false,
  "properties": {
    "plan_approval_id": {"type": "string"},
    "schema_version": {"type": "string", "pattern": "^v[0-9]+$"},
    "session_id": {"type": "string"},
    "plan_id": {"type": "string"},
    "plan_summary": {"type": "string"},
    "planned_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "title", "intent"],
        "additionalProperties": true,
        "properties": {
          "step_id": {"type": "string"},
          "title": {"type": "string"},
          "intent": {"type": "string"}
        }
      }
    },
    "expected_paths": {"type": "array", "items": {"type": "string"}},
    "expected_commands": {"type": "array", "items": {"type": "string"}},
    "model_profile_id": {"type": "string"},
    "governance_risk": {"type": "string", "enum": ["low", "medium", "high"]},
    "request_hash": {"type": "string"}
  }
}

